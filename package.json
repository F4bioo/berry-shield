{
  "name": "berry-shield",
  "version": "1.0.0",
  "description": "Security plugin for OpenClaw - blocks destructive commands, redacts secrets and PII",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "update-patterns": "npx ts-node --esm scripts/update-patterns.ts"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "devDependencies": {
    "@iarna/toml": "^2.2.5",
    "@types/node": "^25.2.2",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}